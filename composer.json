{
    "name": "haschamedia/basetheme",
    "type": "library",
    "description": "Tema Dasar Untuk Laravel Blade dan Komponen Menggunakan Tailwind CSS",
    "keywords": ["haschamedia", "basetheme", "laravel"],
    "license": "MIT",
    "support": {
        "issues": "https://github.com/haschamedia/basetheme/issues",
        "source": "https://github.com/haschamedia/basetheme"
    },
    "authors": [
        {
            "name": "Fariz Huzairi",
            "email": "farizhuzairi@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.1"
    },
    "autoload": {
        "psr-4": {
            "BaseTheme\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BaseTheme\\BaseThemeServiceProvider"
            ]
        }
    }
}
